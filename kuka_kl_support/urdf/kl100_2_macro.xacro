<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="kl100_2_links" params="prefix">
    <!-- links -->
    <link name="${prefix}base_link">
      <visual>
        <geometry>
          <mesh filename="package://kuka_kl_support/meshes/kl100_2/visual/rail_base_link.dae"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://kuka_kl_support/meshes/kl100_2/collision/rail_base_link.stl"/>
        </geometry>
      </collision>
    </link>
    <link name="${prefix}link_1">
      <visual>
        <geometry>
          <mesh filename="package://kuka_kl_support/meshes/kl100_2/visual/rail_moving_link.dae"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://kuka_kl_support/meshes/kl100_2/collision/rail_moving_link.stl"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>
  <xacro:macro name="kl100_2_joints" params="prefix robot_base_link *origin">
    <!-- joints -->
    <joint name="world-${prefix}base_link" type="fixed">
      <parent link="world"/>
      <child link="${prefix}base_link"/>
      <xacro:insert_block name="origin"/>
    </joint>
    <joint name="${prefix}joint_1" type="prismatic">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link_1"/>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-1.0" upper="1.0" effort="702.0" velocity="2.5"/>
    </joint>
    <joint name="${prefix}link_1-${robot_base_link}" type="fixed">
      <parent link="${prefix}link_1"/>
      <child link="${robot_base_link}"/>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.356"/>
    </joint>
  </xacro:macro>
</robot>
